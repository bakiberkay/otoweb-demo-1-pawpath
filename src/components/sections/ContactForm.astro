---
import type { Site, Section } from "../../schema";
import { getString, getStringOptional } from "../../lib/adapter";

type ContactFormSection = Extract<Section, { type: "contact-form" }>;

interface Props {
  section: ContactFormSection;
  site:    Site;
}

const { section, site } = Astro.props;

const heading        = getStringOptional(site, section.headingStringId);
const intro          = getStringOptional(site, section.introStringId);
const submitLabel    = getString(site, section.submitLabelStringId);
const successMessage = getString(site, section.successMessageStringId);
const errorMessage   = getString(site, section.errorMessageStringId);

const fields = section.fields.map(f => ({
  name:        f.name,
  kind:        f.kind,
  required:    f.required ?? false,
  label:       getString(site, f.labelStringId),
  placeholder: getStringOptional(site, f.placeholderStringId),
  options:     f.options?.map(o => ({ value: o.value, label: getString(site, o.labelStringId) })) ?? null,
}));

const inputType = (k: typeof fields[number]["kind"]) =>
  k === "phone"    ? "tel"   :
  k === "checkbox" ? "checkbox" :
  k === "email"    ? "email" :
                     "text";

const netlify   = section.routing.kind === "netlify-forms";
const action    = section.routing.kind === "webhook" ? section.routing.destination : undefined;
const formName  = "contact";
---

<section class="py-20 md:py-28 px-6">
  <div class="max-w-2xl mx-auto">
    {heading && <h2 class="text-3xl md:text-4xl text-center mb-3">{heading}</h2>}
    {intro && <p class="text-muted text-center mb-10">{intro}</p>}

    <form
      name={netlify ? formName : undefined}
      action={action}
      method="POST"
      data-netlify={netlify ? "true" : undefined}
      data-netlify-honeypot={netlify ? "bot-field" : undefined}
      data-success={successMessage}
      data-error={errorMessage}
      class="bg-surface border border-border rounded-md p-6 md:p-8 shadow-soft space-y-5"
    >
      {netlify && <input type="hidden" name="form-name" value={formName} />}
      {netlify && (
        <p class="hidden">
          <label>Don't fill this out if you're human: <input name="bot-field" /></label>
        </p>
      )}

      {fields.map(f => (
        <div>
          <label for={f.name} class="block text-sm text-ink mb-1.5">
            {f.label}{f.required && <span class="text-accent ml-0.5" aria-hidden="true">*</span>}
          </label>
          {f.kind === "textarea" ? (
            <textarea
              id={f.name}
              name={f.name}
              required={f.required}
              placeholder={f.placeholder ?? undefined}
              rows={5}
              class="w-full rounded-sm border border-border bg-cream/30 px-3 py-2 text-ink focus:outline-none focus:border-accent focus:bg-surface transition-colors"
            />
          ) : f.kind === "select" ? (
            <select
              id={f.name}
              name={f.name}
              required={f.required}
              class="w-full rounded-sm border border-border bg-cream/30 px-3 py-2 text-ink focus:outline-none focus:border-accent focus:bg-surface transition-colors"
            >
              {f.options?.map(o => <option value={o.value}>{o.label}</option>)}
            </select>
          ) : f.kind === "checkbox" ? (
            <label class="inline-flex items-center gap-2 text-sm text-muted">
              <input
                id={f.name}
                type="checkbox"
                name={f.name}
                required={f.required}
                class="rounded-sm border-border text-accent focus:ring-accent"
              />
              {f.label}
            </label>
          ) : (
            <input
              id={f.name}
              type={inputType(f.kind)}
              name={f.name}
              required={f.required}
              placeholder={f.placeholder ?? undefined}
              class="w-full rounded-sm border border-border bg-cream/30 px-3 py-2 text-ink focus:outline-none focus:border-accent focus:bg-surface transition-colors"
            />
          )}
        </div>
      ))}

      <button
        type="submit"
        class="w-full px-6 py-3 bg-accent text-cream rounded-md font-medium hover:bg-accent-dark transition-colors shadow-soft"
      >
        {submitLabel}
      </button>
    </form>
  </div>
</section>
