---
import type { Site, Section } from "../../schema";
import { getString, getStringOptional, resolveAssetUrl } from "../../lib/adapter";

type HeroSection = Extract<Section, { type: "hero" }>;

interface Props {
  section: HeroSection;
  site:    Site;
}

const { section, site } = Astro.props;

const eyebrow       = getStringOptional(site, section.eyebrowStringId);
const headline      = getString(site, section.headlineStringId);
const subhead       = getStringOptional(site, section.subheadStringId);
const primaryLabel  = getStringOptional(site, section.primaryCtaLabelStringId);
const secondaryLabel = getStringOptional(site, section.secondaryCtaLabelStringId);
const bgUrl         = section.backgroundAssetId ? resolveAssetUrl(site, section.backgroundAssetId) : null;
---

<section class="relative overflow-hidden">
  {bgUrl && (
    <div
      class="absolute inset-0 -z-10"
      style={`background-image: url('${bgUrl}'); background-size: cover; background-position: center; opacity: 0.35;`}
    />
  )}
  <div class="absolute inset-0 -z-10 bg-gradient-to-b from-cream/0 via-cream/40 to-cream"></div>

  <div class="max-w-4xl mx-auto px-6 py-24 md:py-32 text-center">
    {eyebrow && (
      <p class="text-accent font-medium tracking-wide uppercase text-xs mb-5">
        {eyebrow}
      </p>
    )}
    <h1 class="text-4xl md:text-6xl leading-[1.05] tracking-tight mb-6">
      {headline}
    </h1>
    {subhead && (
      <p class="text-lg md:text-xl text-muted max-w-2xl mx-auto mb-10 leading-relaxed">
        {subhead}
      </p>
    )}
    {(primaryLabel || secondaryLabel) && (
      <div class="flex gap-3 justify-center flex-wrap">
        {primaryLabel && (
          <a
            href={section.primaryCtaHref ?? "#"}
            class="px-6 py-3 bg-accent text-cream rounded-md font-medium hover:bg-accent-dark transition-colors shadow-soft"
          >
            {primaryLabel}
          </a>
        )}
        {secondaryLabel && (
          <a
            href={section.secondaryCtaHref ?? "#"}
            class="px-6 py-3 border border-border text-ink rounded-md font-medium hover:border-accent hover:text-accent transition-colors"
          >
            {secondaryLabel}
          </a>
        )}
      </div>
    )}
  </div>
</section>
